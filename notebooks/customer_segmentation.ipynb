# customer_segmentation.ipynb
# Step 1: Import libraries
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.preprocessing import StandardScaler
from sklearn.cluster import KMeans
import os

# Step 2: Load dataset
df = pd.read_csv("data/train.csv")  # change path if needed
df.head()

# Step 3: Explore data
print("Dataset info:")
df.info()
print("\nFirst 5 rows:")
print(df.head())

# Step 4: Convert Gender to numeric
df['Gender'] = df['Gender'].map({'Male': 0, 'Female': 1})

# Step 5: Select features for clustering
X = df[['Gender', 'Age', 'Annual Income (k$)', 'Spending Score (1-100)']]

# Step 6: Scale features
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)
print("\nFirst 5 rows after scaling:")
print(X_scaled[:5])

# Step 7: Elbow method to choose k
inertia = []
K = range(1, 11)
for k in K:
    kmeans = KMeans(n_clusters=k, random_state=42)
    kmeans.fit(X_scaled)
    inertia.append(kmeans.inertia_)

plt.figure(figsize=(6,4))
plt.plot(K, inertia, 'bo-')
plt.xlabel('Number of clusters (k)')
plt.ylabel('Inertia')
plt.title('Elbow Method')
plt.show()

# Step 8: Train final KMeans with chosen k
chosen_k = 5  # adjust based on elbow
kmeans = KMeans(n_clusters=chosen_k, random_state=42)
kmeans.fit(X_scaled)
df['Cluster'] = kmeans.labels_

# Step 9: Map cluster numbers to names
cluster_names = {
    0: 'Young Big Spenders',
    1: 'Young Medium Spenders',
    2: 'Middle Age Average',
    3: 'Older Low Spenders',
    4: 'Middle Age Big Spenders'
}
df['Cluster Name'] = df['Cluster'].map(cluster_names)
print("\nCluster counts:")
print(df['Cluster Name'].value_counts())

# Step 10: Visualize clusters
plt.figure(figsize=(8,6))
sns.scatterplot(
    data=df,
    x='Annual Income (k$)',
    y='Spending Score (1-100)',
    hue='Cluster Name',
    palette='Set2'
)
plt.title("Customer Segments")
plt.show()

# Step 11: Save final dataset
output_folder = "data"
os.makedirs(output_folder, exist_ok=True)
output_csv_path = os.path.join(output_folder, "customer_segments_final.csv")
df.to_csv(output_csv_path, index=False)
print(f"\nFinal dataset saved to: {output_csv_path}")

# Step 12: Save cluster plot
plot_folder = "outputs/plots"
os.makedirs(plot_folder, exist_ok=True)
plot_save_path = os.path.join(plot_folder, "final_clusters.png")
plt.figure(figsize=(8,6))
sns.scatterplot(
    data=df,
    x='Annual Income (k$)',
    y='Spending Score (1-100)',
    hue='Cluster Name',
    palette='Set2'
)
plt.title("Customer Segments")
plt.savefig(plot_save_path)
print(f"Cluster plot saved to: {plot_save_path}")
plt.close()